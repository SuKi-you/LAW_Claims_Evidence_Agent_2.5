# Dify API 基础地址（不含尾部斜杠）
DIFY_API_BASE_URL=http://localhost/v1

# Intent Discovery App（诉求识别）— Chatflow 类型
DIFY_INTENT_API_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx

# Evidence App（证据清单生成）— Chatflow 类型
DIFY_EVIDENCE_API_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx

# 可选：超时控制（毫秒），默认值已在代码中设置
# VITE_DIFY_INTENT_TIMEOUT_MS=45000
# VITE_DIFY_EVIDENCE_TIMEOUT_MS=60000
